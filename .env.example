# Google Gemini — get a free API key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Optional alias (LangChain also reads this)
# GEMINI_API_KEY=your-google-api-key-here

# Chat model for answers (examples: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash)
GOOGLE_MODEL=gemini-2.5-flash

# Embedding model for indexing papers (do not change without re-indexing)
GOOGLE_EMBEDDING_MODEL=text-embedding-001

# Vector store
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=rag_documents

# Retriever tuning
RETRIEVER_TOP_K=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
